{
  "name": "lens",
  "version": "2.0.2",
  "description": "Search, resume, and understand your AI coding sessions",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n.mjs",
    "build": "tsc --noEmit && vite build",
    "build:icon": "node build/build-icon.mjs",
    "preview": "electron .",
    "start": "npm run dev",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "author": "maliming",
  "license": "MIT",
  "homepage": "https://lens.maliming.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/maliming/Lens.git"
  },
  "bugs": {
    "url": "https://github.com/maliming/Lens/issues"
  },
  "build": {
    "appId": "io.maliming.lens",
    "productName": "Lens",
    "copyright": "Copyright © 2026 maliming",
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts,*.md,*.markdown,test,tests,docs,doc,example,examples,*.map,LICENSE*,license*}",
      "!**/node_modules/@types/**/*",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/**/*.map",
      "!**/node_modules/**/*.flow",
      "!**/node_modules/.cache/**/*",
      "!**/node_modules/.bin/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "extraResources": [
      {
        "from": "build/trayTemplate.png",
        "to": "build/trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "build/trayTemplate@2x.png"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-virtual": "^3.14.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.17",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "overrides": {
    "yauzl": "^3.3.1",
    "shell-quote": "^1.8.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
